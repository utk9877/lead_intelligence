# Copy to .env for local development. No secrets are ever committed.

# --- Postgres (docker-compose service) ---
POSTGRES_USER=li
POSTGRES_PASSWORD=li_dev_password
POSTGRES_DB=lead_intelligence
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://li:li_dev_password@localhost:5432/lead_intelligence

# --- MinIO evidence store (docker-compose service; S3-compatible) ---
MINIO_ROOT_USER=li_minio
MINIO_ROOT_PASSWORD=li_dev_password
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
EVIDENCE_BUCKET=evidence-snapshots

